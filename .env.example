# ──────────────────────────────────────────────────────────────
# Accès Google Sheets — compte de service (service account)
# Copier ce fichier en `.env` et renseigner les valeurs réelles.
# Le `.env` réel est ignoré par git — ne jamais committer de secret.
# ──────────────────────────────────────────────────────────────
#
# Obtenir les valeurs :
#  1. console.cloud.google.com → projet → activer "Google Sheets API"
#  2. IAM & Admin → Comptes de service → créer → Clés → clé JSON
#  3. Dans le JSON : "client_email" et "private_key"
#  4. Partager le Google Sheet avec le client_email en rôle "Éditeur"
#     (sinon l'écriture renvoie 403).
# ──────────────────────────────────────────────────────────────

GOOGLE_SHEET_ID=1bOISBPwoU1xa5R4Um0fRASXKFeclJ8jB3A3CUHBMlI8

GOOGLE_CLIENT_EMAIL="xxxxx@xxxxx.iam.gserviceaccount.com"

GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
